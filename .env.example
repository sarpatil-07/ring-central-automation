# Copy this file to .env and fill in your own values:
#   cp .env.example .env
#
# NEVER commit .env — it can contain passwords.

# --- RingCX (RCAutoLogin) ---
RCX_AGENT_URL=https://app.ringcentral.com/ring_cx/agent?env=production
RCX_LOGIN_ID=you@company.com
RCX_LOGIN_PASSWORD=
RCX_AUTO_LOGIN_ENABLED=true

# --- Schedule (shared by RCAutoLogin / MAX) ---
TIMEZONE=Asia/Kolkata
WORK_DAYS=mon,tue,wed,thu,fri
WORK_START=09:00
WORK_END=18:00
LUNCH_START=13:00
LUNCH_END=14:00
LUNCH_ENABLED=true
AUTORUN_PAUSED=false
LEAVE_DATE=
QUIET_STATUS_JOBS=true

# --- Optional: NICE MAX (legacy run.py) ---
# STATION_ID=
# BROWSER_MODE=launch
# CLOSE_BROWSER_AFTER_RUN=false
# CHROME_MAX_PROFILE_DIR=./chrome-max-profile
