# RCAutoLogin — copy to .env on first install (install.sh does this automatically)
TIMEZONE=Asia/Kolkata
WORK_DAYS=mon,tue,wed,thu,fri
WORK_START=09:00
WORK_END=18:00
LUNCH_ENABLED=true
LUNCH_START=13:00
LUNCH_END=14:00
AUTORUN_PAUSED=false
LEAVE_DATE=

RCX_AGENT_URL=https://app.ringcentral.com/ring_cx/agent?env=production
CHROME_RCX_PROFILE_DIR=./chrome-rcx-profile
CHROME_RCX_CDP_PORT=9334

# Optional — auto sign-in when not logged in (stored locally, never commit .env)
RCX_LOGIN_ID=
RCX_LOGIN_PASSWORD=
RCX_AUTO_LOGIN_ENABLED=false
